{
  "compilerOptions": {
    "lib": ["es2024"],
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "es2024",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": [
    "*.js",
    "bin/**/*.js",
    "api/**/*.js"
  ],
  "exclude": ["node_modules"]
}
